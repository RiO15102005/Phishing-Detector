{
    "manifest_version": 3,

    "name": "Anti Scam Detector",

    "short_name": "ASD",

    "version": "1.0.0",

    "description": "Detect phishing, scam and malicious websites using OSINT, Feature Extraction and AI Analysis.",

    "minimum_chrome_version": "114",

    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },

    "action": {
        "default_title": "Anti Scam Detector",
        "default_popup": "popup/popup.html"
    },

    "background": {
        "service_worker": "background.js",
        "type": "module"
    },

    "permissions": [
        "activeTab",
        "tabs",
        "storage",
        "notifications",
        "scripting"
    ],

    "host_permissions": [
        "<all_urls>",
        "http://127.0.0.1:8000/*",
        "http://localhost:8000/*"
    ],

    "web_accessible_resources": [
        {
            "resources": [
                "icons/*",
                "assets/*"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ]
}