# ====================================
# Application
# ====================================

APP_NAME=AI Anti Scam Chatbot

APP_VERSION=1.0.0

ENVIRONMENT=development

DEBUG=true

HOST=0.0.0.0

PORT=8000


# ====================================
# Gemini
# ====================================

GEMINI_API_KEY=YOUR_GEMINI_API_KEY

GEMINI_MODEL=gemini-2.5-flash


# ====================================
# Gemini - API Key riêng cho từng Agent (tùy chọn)
#
# Để trống nếu muốn Agent dùng chung GEMINI_API_KEY ở trên.
# Chỉ điền khi muốn tách quota/billing/rate-limit riêng cho từng Agent.
# ====================================

GEMINI_API_KEY_PLANNER=

GEMINI_API_KEY_EVALUATION=

GEMINI_API_KEY_QUERY_REWRITE=

GEMINI_API_KEY_ANSWER_VALIDATION=

GEMINI_API_KEY_RISK_ANALYSIS=

GEMINI_API_KEY_RESPONSE=

GEMINI_API_KEY_OUTSIDE_SCOPE=

# ====================================
# Local LLM (Qwen3 4B, chay qua LM Studio - OpenAI-compatible)
# ====================================

LOCAL_LLM_PROVIDER=lmstudio

LOCAL_LLM_BASE_URL=http://127.0.0.1:1234/v1

LOCAL_LLM_API_KEY=lm-studio

LOCAL_LLM_MODEL=qwen3-4b-instruct-2507

LOCAL_LLM_TEMPERATURE=0.1

LOCAL_LLM_MAX_TOKENS=512


# ====================================
# Groq (OpenAI-compatible)
# ====================================

GROQ_API_KEY=YOUR_GROQ_API_KEY

GROQ_API_KEY_RESPONSE=

GROQ_API_KEY_EVALUATION=

GROQ_BASE_URL=https://api.groq.com/openai/v1

GROQ_MODEL=llama-3.3-70b-versatile

GROQ_TEMPERATURE=0.3

GROQ_MAX_TOKENS=1024


# ====================================
# Agent Provider: "local" | "groq" | "gemini"
# Provider chinh loi -> tu dong fallback sang Gemini (key rieng o tren).
# ====================================

PLANNER_PROVIDER=gemini

EVALUATION_PROVIDER=groq

QUERY_REWRITE_PROVIDER=gemini

ANSWER_VALIDATION_PROVIDER=gemini

RESPONSE_PROVIDER=groq


# ====================================
# Redis
# ====================================

REDIS_URL=redis://localhost:6379

REDIS_DB=0


# ====================================
# Pinecone
# ====================================

PINECONE_API_KEY=YOUR_PINECONE_API_KEY

PINECONE_INDEX=anti-scam-chatbot

PINECONE_NAMESPACE_LAW=law

PINECONE_NAMESPACE_SCAM=scam


# ====================================
# Embedding
# ====================================

EMBEDDING_MODEL=intfloat/multilingual-e5-large


# ====================================
# Retrieval
# ====================================

TOP_K=5


# ====================================
# Cache
# ====================================

CACHE_TTL=21600


# ====================================
# HTTP
# ====================================

REQUEST_TIMEOUT=10